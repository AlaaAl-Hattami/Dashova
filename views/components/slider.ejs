<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document</title>
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@3.4.1/dist/tailwind.min.css" rel="stylesheet">

</head>

<body>

  <div id="sidebarId" class="position-relative d-flex flex-column flex-shrink-0 p-3 text-bg-dark sidebar">
    <span style="right: 10px; top: 2px" class="position-absolute">
      <button class="btn" onclick="toggleSidebar()">
        <i class="bi bi-x-circle"></i>
      </button>
    </span>

    <a href="/" class="d-flex align-items-center mb-3 mb-md-0 me-md-auto text-white text-decoration-none">
      <i class="bi bi-lightning-charge"></i>
      <span class="fs-4 sidebar-text">Sidebar</span>
    </a>
    <hr />
    <ul class="nav nav-pills flex-column mb-auto">
      <li class="nav-item">
        <a href="/home" class="nav-link text-white <%= currentPage ==="index" ?"active":null%>" aria-current="page">
          <svg class="bi pe-none me-2" width="16" height="16">
            <use xlink:href="#home" />
          </svg>
          <span class="sidebar-text"> Home </span>
        </a>
      </li>

      <li>
        <a href="../user/add.html" class="nav-link text-white <%= currentPage ==="add" ?"active":null%>">
          <svg class="bi pe-none me-2" width="16" height="16">
            <use xlink:href="#people-circle" />
          </svg>
          <span class="sidebar-text"> Add Customers </span>
        </a>
      </li>
    </ul>
    <hr />
    <div class="dropdown">
      <a href="#" class="d-flex align-items-center text-white text-decoration-none dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
        <img src="<%= user.profileImage ? user.profileImage :"../img/profile_img.png" %>" alt="Profile Image" width="32" height="32" class="rounded-circle me-2" />
        <% if (user !== null) { %>
        <strong class="sidebar-text"><%= user.username %></strong>

        <% } else { %>
        <strong class="sidebar-text"> لايوجد مستخدم</strong>
        <% } %>
      </a>
      <ul class="dropdown-menu dropdown-menu-dark text-small shadow">
        <li><a class="dropdown-item" href="#">New project...</a></li>
        <li><a class="dropdown-item" href="#">Settings</a></li>
        <li>
          <button id="" data-bs-toggle="modal" data-bs-target="#exampleModal" class="dropdown-item" href="#">
            Profile Image
          </button>
        </li>
        <li>
          <hr class="dropdown-divider" />
        </li>
        <li><a class="dropdown-item" href="/singout">Sign out</a></li>
      </ul>
    </div>
  </div>

  <!-- Modal -->
  <div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <form action="/profile" method="post" enctype="multipart/form-data">
        <div class="modal-content">
          <div class="modal-header">
            <h1 class="modal-title fs-5" id="exampleModalLabel"> Change Profile Image
            </h1>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>

          <div class="modal-body text-center py-4">
            <div class="my-4">
              <img id="pro_img" src="<%= user.profileImage ? user.profileImage :"../img/profile_img.png" %>" alt="Profile Image" width="150" height="150" class="rounded-circle border border-4 border-primary shadow-lg mb-3">
            </div>

            <label for="input_file" class="btn btn-outline-primary px-4 py-2 text-white bg-gradient-to-r from-primary to-secondary border-2 border-primary hover:shadow-lg transition duration-300">
              <i class="bi bi-upload me-2"></i> تغيير الصورة
            </label>

            <input name="img" style="display: none;" id="input_file" type="file" class="form-control" />

            <small class="form-text text-muted mt-2">اضغط على الزر لتغيير الصورة الشخصية.</small>
          </div>

          <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">


          <div class="modal-footer">
            <button type="submit" class="btn btn-danger" data-bs-dismiss="modal">Close</button>
            <button type="submit" class="btn btn-primary">Save changes</button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <div class="b-example-divider b-example-vr"></div>


  <script>
    input_file.addEventListener("change", (el) => {
      pro_img.src = URL.createObjectURL(el.target.files[0])

    })
  </script>
</body>

</html>